{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-decomposer/schemas/candidate_decomposition/v1.json",
  "title": "CandidateDecompositions",
  "description": "One or more candidate service decompositions produced by the Decomposition Generator (or a refined variant from the Refiner).",
  "type": "object",
  "additionalProperties": false,
  "required": ["system", "candidates"],
  "properties": {
    "system": {
      "type": "string",
      "enum": ["demo", "jpetstore-6", "spring-petclinic", "PartsUnlimitedMRP"]
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/candidate" }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "generated_at_utc": { "type": "string", "format": "date-time" },
        "model":            { "type": ["string", "null"] },
        "tokens_used":      { "type": ["integer", "null"], "minimum": 0 }
      }
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "strategy", "services", "rationale"],
      "properties": {
        "candidate_id": {
          "type": "string",
          "pattern": "^CAND_[0-9]+(_REFINED_[0-9]+)?$"
        },
        "strategy": {
          "type": "string",
          "enum": ["dependency_first", "domain_first", "balanced", "refined"]
        },
        "services": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/service" }
        },
        "rationale": { "type": "string" },
        "parent_candidate_id": {
          "type": ["string", "null"],
          "description": "Set on refined candidates; points at the candidate they were derived from."
        },
        "refinement_round": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "classes", "responsibilities", "dependencies", "evidence_refs"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "type": "string", "description": "Simple class name." },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["id"],
                "properties": {
                  "id": { "type": "string", "description": "Simple class name; the {id: ...} shape matches the existing baseline decomposition.json format." }
                }
              }
            ]
          }
        },
        "responsibilities": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "description": "Name of another service in this candidate." }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "Stable IDs from evidence_pack or domain_model: C001, BC001, API_001, K_001, ..."
          }
        }
      }
    }
  }
}
